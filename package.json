{
  "name": "stylefind-bot",
  "version": "1.0.0",
  "description": "Telegram-бот для стилиста: анализ фото через Gemini, поиск на WB и Lamoda, PDF-капсула",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.49.4",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/node-fetch": "^2.6.12",
    "@types/node-telegram-bot-api": "^0.64.8",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
